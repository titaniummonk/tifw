/* Enhanced Custom CSS for Wesley "The Titanium Monk" Steehouwer */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

:root {
    --titanium-orange: #ff8c00;
    --titanium-orange-dark: #ff6b00;
    --titanium-orange-light: #ffa500;
    --titanium-dark: #0f0f0f;
    --titanium-gray: #2d2d2d;
    --titanium-light: #1a1a1a;
    --white: #ffffff;
    --light-gray: #e0e0e0;
    --medium-gray: #cccccc;
    --text-gray: #666666;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 140, 0, 0.1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    line-height: 1.6;
    color: var(--white);
    background: linear-gradient(135deg, var(--titanium-dark) 0%, var(--titanium-light) 50%, var(--titanium-gray) 100%);
    min-height: 100vh;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Enhanced Header with Titanium Monk Branding */
header {
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-bottom: 1px solid var(--glass-border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
}

.logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--white);
}

/* Enhanced Zen Circle Logo */
.logo-circle {
    width: 80px;
    height: 80px;
    border: 3px solid var(--titanium-orange);
    border-radius: 50%;
    background: linear-gradient(45deg, rgba(255, 140, 0, 0.1) 0%, rgba(255, 140, 0, 0.3) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20px;
    position: relative;
    animation: pulse 3s ease-in-out infinite;
    box-shadow: 0 0 20px rgba(255, 140, 0, 0.3);
}

@keyframes pulse {
    0%, 100% { 
        transform: scale(1); 
        box-shadow: 0 0 20px rgba(255, 140, 0, 0.3); 
    }
    50% { 
        transform: scale(1.05); 
        box-shadow: 0 0 40px rgba(255, 140, 0, 0.5); 
    }
}

.monk-silhouette {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--titanium-orange-dark) 100%);
    clip-path: polygon(30% 10%, 70% 10%, 80% 30%, 75% 70%, 70% 85%, 30% 85%, 25% 70%, 20% 30%);
    opacity: 0.9;
}

.logo-text h1 {
    font-size: 1.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--white) 50%, var(--titanium-orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2px;
    letter-spacing: -1px;
}

.logo-text .subtitle {
    font-size: 0.9rem;
    color: var(--titanium-orange);
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
}

/* Enhanced Navigation */
nav ul {
    display: flex;
    list-style: none;
    gap: 2rem;
}

nav a {
    text-decoration: none;
    color: var(--medium-gray);
    font-weight: 500;
    padding: 0.8rem 1.5rem;
    border-radius: 25px;
    transition: all 0.3s ease;
    position: relative;
    background: var(--glass-bg);
    border: 1px solid transparent;
}

nav a:hover,
nav a.active {
    color: var(--white);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 15px rgba(255, 140, 0, 0.2);
}

nav a.active {
    color: var(--titanium-orange);
    border-color: var(--titanium-orange);
}

/* Main Content */
main {
    min-height: calc(100vh - 140px);
    padding: 2rem 0;
}

/* Hero Section - Enhanced */
.hero {
    text-align: center;
    padding: 6rem 0;
    margin-bottom: 4rem;
    position: relative;
}

.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at center, rgba(255, 140, 0, 0.1) 0%, transparent 70%);
    pointer-events: none;
}

.hero h2 {
    font-size: 4rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--white) 50%, var(--titanium-orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.5rem;
    letter-spacing: -2px;
}

.hero .subtitle {
    font-size: 1.4rem;
    color: var(--medium-gray);
    font-style: italic;
    margin-bottom: 2rem;
    font-weight: 300;
}

.hero p {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.8;
    color: var(--light-gray);
}

/* Glass Card Design System */
.glass-card {
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    padding: 2rem;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
}

.glass-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    border-color: rgba(255, 140, 0, 0.2);
}

/* Content Sections */
.content-section {
    margin-bottom: 4rem;
}

.section-title {
    font-size: 2.2rem;
    font-weight: 600;
    color: var(--titanium-orange);
    margin-bottom: 2rem;
    position: relative;
    padding-bottom: 15px;
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, var(--titanium-orange), transparent);
}

/* Philosophy/Content Grid */
.content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
}

.content-card {
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    border: 1px solid var(--glass-border);
    padding: 2rem;
    transition: all 0.3s ease;
}

.content-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 140, 0, 0.3);
}

.content-card h4 {
    color: var(--titanium-orange);
    font-size: 1.3rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.content-card p {
    color: var(--light-gray);
    line-height: 1.6;
}

/* Blog/Article Styles */
.blog-article {
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    border: 1px solid var(--glass-border);
    padding: 2rem;
    margin-bottom: 2rem;
    transition: all 0.3s ease;
}

.blog-article:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 140, 0, 0.3);
}

.blog-article h4 a {
    color: var(--white);
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 600;
}

.blog-article h4 a:hover {
    color: var(--titanium-orange);
}

.blog-date {
    color: var(--medium-gray);
    font-size: 0.9rem;
    margin: 0.5rem 0 1rem 0;
}

.blog-excerpt {
    color: var(--light-gray);
    line-height: 1.6;
    margin-bottom: 1rem;
}

.read-more {
    color: var(--titanium-orange);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    border: 1px solid var(--titanium-orange);
    transition: all 0.3s ease;
    display: inline-block;
}

.read-more:hover {
    background: var(--titanium-orange);
    color: var(--titanium-dark);
}

/* Resume-specific Styles */
.resume-header {
    text-align: center;
    margin-bottom: 4rem;
    padding: 3rem 0;
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
}

.resume-title {
    font-size: 3.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--white) 50%, var(--titanium-orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    letter-spacing: -2px;
}

.contact-info {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
}

.contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--medium-gray);
    font-size: 1rem;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
}

.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.skill-category {
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    border-radius: 15px;
    padding: 2rem;
    border: 1px solid var(--glass-border);
}

.skill-category h3 {
    color: var(--titanium-orange);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
}

.skill-tag {
    background: rgba(255, 140, 0, 0.1);
    color: var(--white);
    padding: 0.6rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    border: 1px solid rgba(255, 140, 0, 0.3);
    transition: all 0.3s ease;
}

.skill-tag:hover {
    background: rgba(255, 140, 0, 0.2);
    transform: translateY(-2px);
}

/* Button Styles - Enhanced */
.btn {
    display: inline-block;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--titanium-orange-dark) 100%);
    color: var(--white);
    text-decoration: none;
    border-radius: 25px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(255, 140, 0, 0.3);
}

.btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(255, 140, 0, 0.4);
}

.btn-outline {
    background: transparent;
    color: var(--titanium-orange);
    border: 2px solid var(--titanium-orange);
    box-shadow: none;
}

.btn-outline:hover {
    background: var(--titanium-orange);
    color: var(--titanium-dark);
}

/* CTA Section */
.cta-section {
    text-align: center;
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    padding: 4rem 2rem;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    margin: 4rem 0;
}

.cta-section h3 {
    color: var(--titanium-orange);
    font-size: 2rem;
    margin-bottom: 1rem;
}

.cta-section p {
    color: var(--light-gray);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

/* Footer */
footer {
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-top: 1px solid var(--glass-border);
    color: var(--medium-gray);
    text-align: center;
    padding: 3rem 0;
    margin-top: 4rem;
}

footer p {
    margin-bottom: 0.5rem;
}

.footer-brand {
    color: var(--titanium-orange);
    font-weight: 600;
}

/* Article Content */
.article-content {
    max-width: 900px;
    margin: 0 auto;
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    padding: 3rem;
}

.content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--light-gray);
}

.content h1, .content h2, .content h3, .content h4, .content h5, .content h6 {
    color: var(--titanium-orange);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
}

.content h2 {
    font-size: 1.8rem;
    border-bottom: 2px solid var(--titanium-orange);
    padding-bottom: 0.5rem;
}

.content blockquote {
    border-left: 4px solid var(--titanium-orange);
    padding-left: 2rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--medium-gray);
    background: rgba(255, 140, 0, 0.05);
    padding: 1.5rem 2rem;
    border-radius: 0 10px 10px 0;
}

.content code {
    background: rgba(255, 140, 0, 0.1);
    color: var(--titanium-orange);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.9em;
}

.content pre {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 2rem;
    border-radius: 15px;
    overflow-x: auto;
    margin: 2rem 0;
}

/* Responsive Design */
@media (max-width: 768px) {
    .header-content {
        flex-direction: column;
        gap: 1.5rem;
        padding: 1.5rem 0;
    }

    nav ul {
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .hero h2 {
        font-size: 2.5rem;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
    }

    .monk-silhouette {
        width: 35px;
        height: 35px;
    }

    .logo-text h1 {
        font-size: 1.4rem;
    }

    .container {
        padding: 0 15px;
    }

    .content-grid,
    .skills-grid {
        grid-template-columns: 1fr;
    }

    .contact-info {
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .resume-title {
        font-size: 2.5rem;
    }

    .article-content {
        padding: 2rem 1.5rem;
    }
}

@media (max-width: 480px) {
    .hero h2 {
        font-size: 2rem;
    }
    
    .hero .subtitle {
        font-size: 1.1rem;
    }
    
    .hero p {
        font-size: 1rem;
    }
    
    .section-title {
        font-size: 1.8rem;
    }
}
