{{ define "main" }}
<div class="container">
    <!-- Header with Zen Circle Logo -->
    <header class="header">
        <div class="logo-container">
            <div class="zen-circle">
                <div class="monk-silhouette"></div>
            </div>
        </div>
        <div class="name-title">
            <h1 class="name">{{ .Params.name | upper }}</h1>
            <p class="subtitle">{{ .Params.nickname }}</p>
            <p class="tagline">"{{ .Params.tagline }}"</p>
        </div>
        <div class="contact-info">
            <div class="contact-item">📍 {{ .Params.location }}</div>
            <div class="contact-item">📞 {{ .Params.phone }}</div>
            <div class="contact-item">✉ {{ .Params.email }}</div>
        </div>
    </header>

    <!-- Main Content -->
    <article class="article-content">
        <div class="content">
            {{ .Content }}
        </div>
    </article>
</div>

<!-- Additional CSS for Resume-specific styling -->
<style>
/* Resume-specific enhancements to work with your custom.css */
.header {
    text-align: center;
    margin-bottom: 60px;
    position: relative;
    background: var(--glass-bg);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    padding: 40px;
}

.logo-container {
    display: inline-block;
    position: relative;
    margin-bottom: 30px;
}

.zen-circle {
    width: 200px;
    height: 200px;
    border: 8px solid var(--titanium-orange);
    border-radius: 50%;
    position: relative;
    margin: 0 auto;
    background: linear-gradient(45deg, rgba(255, 140, 0, 0.1) 0%, rgba(255, 140, 0, 0.3) 100%);
    animation: pulse 3s ease-in-out infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(255, 140, 0, 0.3); }
    50% { transform: scale(1.05); box-shadow: 0 0 40px rgba(255, 140, 0, 0.5); }
}

.monk-silhouette {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--titanium-orange-dark) 100%);
    clip-path: polygon(30% 10%, 70% 10%, 80% 30%, 75% 70%, 70% 85%, 30% 85%, 25% 70%, 20% 30%);
    opacity: 0.9;
}

.name-title {
    margin-top: 20px;
}

.name {
    font-size: 3.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--titanium-orange) 0%, var(--white) 50%, var(--titanium-orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
    letter-spacing: -2px;
}

.subtitle {
    font-size: 1.4rem;
    color: var(--medium-gray);
    font-weight: 300;
    margin-bottom: 20px;
}

.tagline {
    font-size: 1.1rem;
    color: var(--titanium-orange);
    font-style: italic;
    max-width: 600px;
    margin: 0 auto;
}

.contact-info {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-top: 30px;
    flex-wrap: wrap;
}

.contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--medium-gray);
    font-size: 0.95rem;
    padding: 0.5rem 1rem;
    background: var(--glass-bg);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
}

/* Titanium Story Styling */
.titanium-story {
    background: linear-gradient(135deg, rgba(255, 140, 0, 0.1) 0%, rgba(255, 140, 0, 0.05) 100%);
    border: 2px solid rgba(255, 140, 0, 0.3);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    margin: 50px 0;
}

.titanium-story h2 {
    color: var(--titanium-orange);
    font-size: 2.2rem;
    margin-bottom: 20px;
    font-weight: 700;
}

.titanium-story p {
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--light-gray);
    max-width: 800px;
    margin: 0 auto;
}

/* Key Achievements Grid */
.key-achievements {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin: 2rem 0;
}

.achievement-item {
    background: rgba(255, 140, 0, 0.05);
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    border: 1px solid rgba(255, 140, 0, 0.2);
    transition: transform 0.3s ease;
}

.achievement-item:hover {
    transform: translateY(-5px);
}

.achievement-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--titanium-orange);
    display: block;
    margin-bottom: 10px;
}

.achievement-text {
    color: var(--light-gray);
    font-size: 0.95rem;
    line-height: 1.4;
}

/* Enhanced content styling */
.content h2 {
    font-size: 2rem;
    font-weight: 600;
    color: var(--titanium-orange);
    margin: 2rem 0 1.5rem 0;
    position: relative;
    padding-bottom: 15px;
}

.content h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--titanium-orange), transparent);
}

.content h3 {
    color: var(--titanium-orange);
    font-size: 1.3rem;
    margin: 1.5rem 0 1rem 0;
    font-weight: 600;
}

.content h4 {
    color: var(--white);
    font-size: 1.1rem;
    margin: 1rem 0 0.5rem 0;
    font-weight: 600;
}

.content ul {
    margin: 1rem 0;
    padding-left: 0;
    list-style: none;
}

.content ul li {
    position: relative;
    padding-left: 25px;
    margin-bottom: 12px;
    color: var(--light-gray);
    line-height: 1.6;
}

.content ul li::before {
    content: '▶';
    position: absolute;
    left: 0;
    color: var(--titanium-orange);
    font-weight: bold;
}

.content strong {
    color: var(--titanium-orange);
    font-weight: 500;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .name {
        font-size: 2.5rem;
    }
    
    .contact-info {
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }
    
    .zen-circle {
        width: 150px;
        height: 150px;
    }
    
    .monk-silhouette {
        width: 90px;
        height: 90px;
    }
    
    .key-achievements {
        grid-template-columns: 1fr;
    }
}
</style>
{{ end }}
